# ==============================================================================
# HACKATHON BACKEND ENVIRONMENT CONFIGURATION
# ==============================================================================
# Team Note: Copy this file to '.env' if not already present.
# The user/team lead will update app settings here.

# Express Server Port (Frontend connects to this port via proxy/axios baseURL)
PORT=5000

# Frontend URL allowed for CORS & HTTP-Only Cookies
FRONTEND_URL=http://localhost:5173

# ==============================================================================
# CLOUD SUPABASE CONFIGURATION (PostgreSQL + Auth)
# ==============================================================================
# 1. Go to https://supabase.com -> Open your Project -> Project Settings -> API
# 2. Paste your Project URL under SUPABASE_URL
# 3. Paste your `anon` public key OR `service_role` secret key under SUPABASE_ANON_KEY
# ==============================================================================
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_or_service_role_key

# Secret key used for signing session cookies / JWT tokens
SESSION_SECRET=hackathon_super_secret_session_key_2026
